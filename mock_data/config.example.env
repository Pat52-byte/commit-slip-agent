# =============================================
# COMMIT SLIP AGENT — Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Salesforce (via CData) ---
SALESFORCE_USERNAME=your@email.com
SALESFORCE_PASSWORD=yourpassword
SALESFORCE_SECURITY_TOKEN=yourtoken
SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com

# --- Attention ---
ATTENTION_API_KEY=your-attention-api-key
ATTENTION_BASE_URL=https://api.attentioninsight.com/v1

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_TARGET_USER_ID=U01234HASSAN

# --- Google Calendar ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# --- Agent Config ---
REPORT_SEND_HOUR=7
REPORT_SEND_TIMEZONE=America/New_York
SLIP_RATE_TARGET=0.15
CALL_INACTIVITY_THRESHOLD_DAYS=14
MAX_DEALS_BEFORE_PDF=5
